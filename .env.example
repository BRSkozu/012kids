# 012.kids 環境変数サンプル
# このファイルを `.env.local` にコピーして値を埋めてください。
# .env.local はコミット対象外です。

# ----------------------------------------------------------------------------
# Build / deploy
# ----------------------------------------------------------------------------

# 静的書き出し（GitHub Pages 用）。Vercel 等の動的デプロイでは未設定のままに。
# GITHUB_PAGES=true

# basePath（GitHub Pages のサブパス配信時のみ）。
# NEXT_PUBLIC_BASE_PATH=/012kids

# 下書き記事も表示する（ローカル確認用、本番では未設定）。
# SHOW_DRAFTS=true

# ----------------------------------------------------------------------------
# Analytics
# ----------------------------------------------------------------------------

# Google Analytics 4 測定 ID（クライアント計測）。
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# `scripts/generate-access-report.mjs` 用（GA Data API）。
# GA_PROPERTY_ID=000000000
# GA_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'

# ----------------------------------------------------------------------------
# Contact form
# ----------------------------------------------------------------------------

# 送信先エンドポイントのオーバーライド。
# 静的書き出し（GitHub Pages）では /api/contact が使えないため、
# Formspree / Web3Forms 等の外部サービスの URL を指定する。
# 未設定なら /api/contact を使用。
# NEXT_PUBLIC_CONTACT_ENDPOINT=https://formspree.io/f/xxxx

# /api/contact のメール送信に Resend を使う場合のみ設定。
# 未設定の場合はサーバーログに出力するだけ（開発用フォールバック）。
# RESEND_API_KEY=re_xxxxxxxxxxxx
# CONTACT_TO_EMAIL=hello@012.kids
# CONTACT_FROM_EMAIL=noreply@012.kids
